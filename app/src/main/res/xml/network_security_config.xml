<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- 默认允许所有明文流量（用户自行配置端点，可能为本地 HTTP 服务） -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
